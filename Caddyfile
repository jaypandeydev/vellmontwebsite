# Caddyfile for vellmontservices.com
#
# This file MIRRORS the live production config at /etc/caddy/Caddyfile on the
# VPS (deploy@147.93.106.12 / srv719322). It is documentation + disaster
# recovery — the CI deploy (.github/workflows/deploy.yml) only rsyncs ./dist/,
# it does NOT copy this file.
#
# To restore this config onto the server (e.g. after a rebuild):
#   scp Caddyfile deploy@147.93.106.12:/tmp/Caddyfile
#   ssh deploy@147.93.106.12 "sudo mv /tmp/Caddyfile /etc/caddy/Caddyfile \
#       && sudo caddy validate --config /etc/caddy/Caddyfile \
#       && sudo systemctl reload caddy"

www.vellmontservices.com {
    redir https://vellmontservices.com{uri} permanent
}

vellmontservices.com {
    root * /var/www/vellmontservices.com

    encode zstd gzip

    # SPA fallback — serve the requested file if it exists, otherwise
    # index.html. Without this line, deep routes like /contact,
    # /privacy-policy, and /terms return 404 on direct hits, and Google
    # cannot index them.
    try_files {path} /index.html
    file_server

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    log {
        output file /var/log/caddy/vellmontservices.log
    }
}
