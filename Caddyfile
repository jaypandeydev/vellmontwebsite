# ⚠️ REFERENCE FRAGMENT — NOT a deployable file. DO NOT scp this over
# /etc/caddy/Caddyfile.
#
# The production Caddyfile on the VPS is a SHARED, multi-site config that
# hosts many unrelated domains (sanatanmahaparishad.org, invitesync.com,
# api.invitesync.com, vellbill.com, vedjyotix.com, medquepms.vellmontservices.com,
# vellroute.com + admin/api/platform, tutorra.vellmontservices.com,
# paperclip.vellmontservices.com, and more). Overwriting that file with this
# one would take every other site on the server offline.
#
# This fragment documents ONLY the vellmontservices.com site block, so this
# project's serving config is reviewable in version control. To change it,
# hand-edit just the `vellmontservices.com { }` block in /etc/caddy/Caddyfile
# on the server, then: sudo caddy validate && sudo systemctl reload caddy

vellmontservices.com {
    root * /var/www/vellmontservices.com

    encode zstd gzip

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    # Legacy product pages (glowzy, courtmate, marrysmartai, medical-queue)
    # have been retired. Return 410 Gone so search engines de-index them
    # instead of being served the SPA shell as a soft 404.
    handle /products/* {
        respond 410
    }

    # Everything else: single-page app with history-mode fallback. Serve the
    # requested file if it exists, otherwise index.html so React Router can
    # resolve the route. Without this, deep links like /contact, /terms, and
    # /privacy-policy return 404 on direct hits.
    handle {
        try_files {path} /index.html
        file_server
    }

    log {
        output file /var/log/caddy/vellmontservices.log
    }
}
